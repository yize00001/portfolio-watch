# Copy this file to .env and fill in your own values.
# .env is git-ignored — never commit real tokens or personal data.

PORTFOLIO_FILE=data/portfolio.csv

# Price provider: mock | yfinance
PRICE_PROVIDER=mock

# Notifier: none | telegram
NOTIFIER=none

# Required when NOTIFIER=telegram
# 1. Talk to @BotFather on Telegram -> /newbot -> copy the token
# 2. Send any message to your bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    and copy the "id" field under "chat"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

CHECK_INTERVAL_SECONDS=300
MARKET_TIMEZONE=Asia/Taipei
